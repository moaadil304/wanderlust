<style>
    .search-btn {
        background-color: #fe424d;
        color: #fff;
        border-radius: 25px;
        padding: 0 1rem;
    }

    .search-btn:hover {
        background-color: #fe424d;
        color: #fff;
    }

    .search-btn i {
        margin-right: 0.5rem;
    }

    .search-input {
        border-radius: 25px;
        padding: 0.5rem 2rem;
        font-size: 1rem;
    }

    /* layout fix */
    .search-form {
        flex: 1;
        max-width: 400px;
    }

    /* ===== RESPONSIVE ===== */

    /* Tablet */
    @media (max-width: 1024px) {
        .search-input {
            padding: 0.4rem 1.5rem;
            font-size: 0.9rem;
        }

        .search-btn {
            padding: 0.3rem 0.8rem;
            font-size: 0.9rem;
        }
    }

    /* Mobile */
    @media (max-width: 600px) {

        .search-form {
            max-width: 180px;
        }

        .search-input {
            padding: 0.3rem 1rem;
            font-size: 0.8rem;
        }

        .search-btn {
            padding: 0.3rem 0.6rem;
            font-size: 0.8rem;
        }

        /* hide text */
        .search-btn span {
            display: none;
        }

        .search-btn i {
            margin: 0;
        }
    }
    /* ===== RIGHT SIDEBAR NAV ===== */

@media (max-width: 768px){

    .sidebar-menu{
        position: fixed;
        top: 0;
        right: -100%;   /* hidden initially */
        height: 40vh;
        width: 40%;
        background-color: white;
        flex-direction: column;
        padding: 2rem 1rem;
        transition: 0.3s ease-in-out;
        z-index: 1050;
    }

    /* when open */
    .sidebar-menu.show{
        right: 0;
    }

    /* links vertical */
    .sidebar-menu .navbar-nav{
        flex-direction: column;
        align-items: flex-start;
    }

    .sidebar-menu .nav-link{
        margin: 10px 0;
        font-size: 1.1rem;
    }
}
</style>


<nav class="navbar navbar-expand-md navbar-light bg-light border-bottom sticky-top">

    <div class="container-fluid d-flex align-items-center">

        <!-- Logo -->
        <a class="navbar-brand" href="/listings">
            <i class="fa-regular fa-compass"></i>
        </a>

        <!-- 🔥 SEARCH (BEFORE HAMBURGER) -->
        <form class="d-flex mx-2 search-form" role="search">
            <input class="form-control me-2 search-input" type="search" placeholder="Search destination" />
            <button class="btn search-btn" type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
                <span>Search</span>
            </button>
        </form>

        <!-- Hamburger -->
        <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Collapsible content -->
        <div class="collapse navbar-collapse sidebar-menu" id="navbarNavAltMarkup">

            <!-- <div class="navbar-nav">
                <a class="nav-link" href="/listings">Explore</a>
            </div> -->

            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/listings">Explore</a>
                <a class="nav-link" href="/listings/new">Airbnb your home</a>

                <% if(!currUser) { %>
                    <a class="nav-link" href="/signup"><b>Sign up</b></a>
                    <a class="nav-link" href="/login"><b>Login</b></a>
                    <% } %>

                        <% if(currUser) { %>
                            <a class="nav-link" href="/logout"><b>Logout</b></a>
                            <% } %>
            </div>

        </div>
    </div>
</nav>

<script>
    document.addEventListener("click", function (event) {

        const sidebar = document.getElementById("navbarNavAltMarkup");
        const toggler = document.querySelector(".navbar-toggler");

        // check if sidebar is open
        if (sidebar.classList.contains("show")) {

            // if click is outside sidebar AND not on toggler
            if (!sidebar.contains(event.target) && !toggler.contains(event.target)) {

                // close sidebar
                const bsCollapse = bootstrap.Collapse.getInstance(sidebar);
                bsCollapse.hide();
            }
        }
    });
</script>